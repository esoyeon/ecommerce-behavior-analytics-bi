# Copy this file to ~/.dbt/profiles.yml or to ./profiles.yml
# and update the credentials as needed

retail_analytics:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', 'localhost') }}"
      port: "{{ env_var('POSTGRES_PORT', '5432') | int }}"
      user: "{{ env_var('POSTGRES_USER', 'retail') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'retail_password') }}"
      dbname: "{{ env_var('POSTGRES_DB', 'retail_db') }}"
      schema: public
      threads: 4
